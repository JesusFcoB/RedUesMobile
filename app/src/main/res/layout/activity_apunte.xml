<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/guinda">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardApunte"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="80dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toTopOf="@+id/toolbarApunte"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">


            <TextView
                android:id="@+id/txtTituloApunte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-black"
                android:text="Crear apunte"
                android:textColor="#9a3412"
                android:textSize="28sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <HorizontalScrollView
                android:id="@+id/scrollFormato"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="#F5F5F5"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/txtTituloApunte">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnNegrita"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:text="B"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/white"
                        android:padding="0dp"
                        android:backgroundTint="#5e0715"
                        android:layout_marginEnd="4dp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnCursiva"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:text="I"
                        android:textStyle="italic"
                        android:textSize="18sp"
                        android:textColor="@color/white"
                        android:padding="0dp"
                        android:backgroundTint="#5e0715"
                        android:layout_marginEnd="4dp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnSubrayado"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:text="U"
                        android:textSize="18sp"
                        android:textColor="@color/white"
                        android:padding="0dp"
                        android:backgroundTint="#5e0715"
                        android:layout_marginEnd="4dp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnTitulo"
                        android:layout_width="55dp"
                        android:layout_height="45dp"
                        android:text="H1"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:padding="0dp"
                        android:backgroundTint="#5e0715"
                        android:layout_marginEnd="4dp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnLista"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:text="•≡"
                        android:textSize="20sp"
                        android:textColor="@color/white"
                        android:padding="0dp"
                        android:backgroundTint="#5e0715"
                        android:layout_marginEnd="4dp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnLimpiar"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:text="Tₓ"
                        android:textSize="18sp"
                        android:textColor="@color/white"
                        android:padding="0dp"
                        android:backgroundTint="#5e0715"
                        android:layout_marginEnd="4dp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnDeshacer"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:text="↩"
                        android:textSize="20sp"
                        android:textColor="@color/white"
                        android:padding="0dp"
                        android:backgroundTint="#5e0715" />
                </LinearLayout>
            </HorizontalScrollView>

            <jp.wasabeef.richeditor.RichEditor
                android:id="@+id/editor"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_margin="10dp"
                android:background="@color/fondoLogin"
                app:layout_constraintBottom_toTopOf="@+id/btnAgregarApunte"
                app:layout_constraintTop_toBottomOf="@+id/scrollFormato" />

            <Button
                android:id="@+id/btnAgregarApunte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:backgroundTint="@color/naranja_oscuro"
                android:text="Publicar"
                app:icon="@drawable/add_publicacion"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarApunte"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#3e0410"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">
            <ImageView android:id="@+id/btnInicio" android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/inicio" />
            <ImageView android:id="@+id/btnCrearApunte" android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/crear_apunte" />
            <ImageView android:id="@+id/btnCrearPublicacion" android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/crear_publicacion" />
            <ImageView android:id="@+id/btnPerfil" android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/perfil_boton" />
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

</androidx.constraintlayout.widget.ConstraintLayout>