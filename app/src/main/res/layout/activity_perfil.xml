<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/guinda"
    android:paddingHorizontal="10dp"
    android:paddingVertical="10dp"
    tools:context=".Perfil">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarPerfil"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="#3e0410"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="4">

            <ImageView
                android:id="@+id/btnInicio"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Inicio"
                android:focusable="true"
                android:src="@drawable/inicio" />

            <ImageView
                android:id="@+id/btnCrearApunte"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Crear apunte"
                android:focusable="true"
                android:src="@drawable/crear_apunte" />

            <ImageView
                android:id="@+id/btnCrearPublicacion"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Crear publicación"
                android:focusable="true"
                android:src="@drawable/crear_publicacion" />

            <ImageView
                android:id="@+id/btnPerfil"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Perfil"
                android:focusable="true"
                android:src="@drawable/perfil_boton" />

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardPerfil"
        android:layout_width="382dp"
        android:layout_height="200dp"
        android:layout_marginTop="10dp"
        app:cardBackgroundColor="#3e0410"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btnPublicacionesGuardadas"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginLeft="170dp"
            android:layout_marginTop="150dp"
            android:backgroundTint="@color/naranja_oscuro"
            android:text="Publicaciones guardadas"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/contSeguidos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="300dp"
            android:layout_marginTop="100dp"
            android:fontFamily="sans-serif-black"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/contSeguidores"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="200dp"
            android:layout_marginTop="100dp"
            android:fontFamily="sans-serif-black"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtSeguidos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="120dp"
            android:layout_marginEnd="50dp"
            android:fontFamily="sans-serif-light"
            android:text="Seguidos"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/txtSeguidores"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="170dp"
            android:layout_marginTop="120dp"
            android:fontFamily="sans-serif-light"
            android:text="Seguidores"
            android:textColor="@color/white" />

        <ImageView
            android:id="@+id/perfil"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_gravity="top|left"
            android:src="@drawable/perfil_boton" />

        <TextView
            android:id="@+id/txtUsuarioPerfil"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="60sp"
            android:layout_marginTop="15sp"
            android:fontFamily="sans-serif-black"
            android:text="Usuario"
            android:textColor="@color/white"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/contPublicaciones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="90dp"
            android:layout_marginTop="100dp"
            android:fontFamily="sans-serif-black"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtCarrera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="130dp"
            android:layout_marginTop="60dp"
            android:fontFamily="sans-serif-light"
            android:text="Carrera"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtSemestre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="180dp"
            android:layout_marginTop="60dp"
            android:fontFamily="sans-serif-light"
            android:text="- Semestre"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/txtPublicaciones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="50dp"
            android:layout_marginTop="120dp"
            android:fontFamily="sans-serif-light"
            android:text="Publicaciones"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/btnEditarPerfil"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginLeft="50dp"
            android:layout_marginTop="150dp"
            android:backgroundTint="@color/naranja_oscuro"
            android:text="Editar perfil"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/btnCerrarSesion"
            android:layout_width="48sp"
            android:layout_height="48sp"
            android:layout_gravity="top|right"
            android:layout_marginTop="10dp"
            android:layout_marginRight="10dp"
            android:clickable="true"
            android:contentDescription="Cerrar sesión"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/cerrar_sesion" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/textView10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Publicaciones"
        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardPerfil" />

    <androidx.cardview.widget.CardView
        android:layout_width="382dp"
        android:layout_height="200dp"
        android:layout_marginTop="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView10">

        <ImageView
            android:id="@+id/btnComentar2"
            android:layout_width="49dp"
            android:layout_height="49dp"
            android:layout_gravity="top|right"
            android:layout_marginTop="10dp"
            android:layout_marginRight="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Comentar"
            android:focusable="true"
            android:src="@drawable/comentario" />

        <ImageView
            android:id="@+id/btnGuardar2"
            android:layout_width="49dp"
            android:layout_height="49dp"
            android:layout_gravity="top|right"
            android:layout_marginTop="10dp"
            android:layout_marginRight="58dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Guardar publicación"
            android:focusable="true"
            android:src="@drawable/guardado" />

        <ImageView
            android:id="@+id/btnLike2"
            android:layout_width="49dp"
            android:layout_height="49dp"
            android:layout_gravity="top|right"
            android:layout_marginTop="10dp"
            android:layout_marginRight="106dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Dar like"
            android:focusable="true"
            android:src="@drawable/like" />

        <TextView
            android:id="@+id/txtUsuarioPost2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|left"
            android:layout_marginLeft="61dp"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif-black"
            android:text="Usuario"
            android:textSize="25sp" />

        <ImageView
            android:id="@+id/perfil2"
            android:layout_width="49dp"
            android:layout_height="49dp"
            android:layout_gravity="top|left"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:src="@drawable/perfil" />

        <androidx.cardview.widget.CardView
            android:id="@+id/contenido"
            android:layout_width="337dp"
            android:layout_height="122dp"
            android:layout_gravity="bottom|center"
            android:layout_marginBottom="10dp"
            android:backgroundTint="@color/fondoLogin" />
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>