<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/guinda"
    android:paddingHorizontal="10dp"
    android:paddingVertical="10dp"
    tools:context=".ui.Perfil">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarPerfil"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="#3e0410"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="4">

            <ImageView
                android:id="@+id/btnInicio"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Inicio"
                android:focusable="true"
                android:src="@drawable/inicio" />

            <ImageView
                android:id="@+id/btnCrearApunte"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Crear apunte"
                android:focusable="true"
                android:src="@drawable/crear_apunte" />

            <ImageView
                android:id="@+id/btnCrearPublicacion"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Crear publicación"
                android:focusable="true"
                android:src="@drawable/crear_publicacion" />

            <ImageView
                android:id="@+id/btnPerfil"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Perfil"
                android:focusable="true"
                android:src="@drawable/perfil_boton" />

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardPerfil"
        android:layout_width="382dp"
        android:layout_height="210dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#3e0410"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">


            <Button
                android:id="@+id/btnPublicacionesGuardadas"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="28dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/naranja_oscuro"
                android:text="Publicaciones guardadas"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/contSeguidos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="0dp"
                android:fontFamily="sans-serif-black"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:layout_constraintBottom_toTopOf="@+id/txtSeguidos"
                app:layout_constraintEnd_toEndOf="@+id/txtSeguidos"
                app:layout_constraintStart_toStartOf="@+id/txtSeguidos" />

            <TextView
                android:id="@+id/contSeguidores"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="0dp"
                android:fontFamily="sans-serif-black"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:layout_constraintBottom_toTopOf="@+id/txtSeguidores"
                app:layout_constraintEnd_toEndOf="@+id/txtSeguidores"
                app:layout_constraintStart_toStartOf="@+id/txtSeguidores" />

            <TextView
                android:id="@+id/txtSeguidos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="40dp"
                android:fontFamily="sans-serif-light"
                android:text="Seguidos"
                android:textColor="@color/white"
                app:layout_constraintBottom_toBottomOf="@+id/txtSeguidores"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/txtSeguidores"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:text="Seguidores"
                android:textColor="@color/white"
                app:layout_constraintBottom_toBottomOf="@+id/txtPublicaciones"
                app:layout_constraintEnd_toStartOf="@+id/txtSeguidos"
                app:layout_constraintStart_toEndOf="@+id/txtPublicaciones" />

            <ImageView
                android:id="@+id/perfil"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:layout_gravity="top|left"
                android:layout_marginStart="12dp"
                android:layout_marginTop="12dp"
                android:src="@drawable/perfil_boton"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtUsuarioPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-black"
                android:text="Usuario"
                android:textColor="@color/white"
                android:textSize="20sp"
                app:layout_constraintStart_toEndOf="@+id/perfil"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/contPublicaciones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="0dp"
                android:fontFamily="sans-serif-black"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:layout_constraintBottom_toTopOf="@+id/txtPublicaciones"
                app:layout_constraintEnd_toEndOf="@+id/txtPublicaciones"
                app:layout_constraintStart_toStartOf="@+id/txtPublicaciones" />

            <TextView
                android:id="@+id/txtCarrera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="sans-serif-light"
                android:text="Carrera"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="@+id/txtSemestre"
                app:layout_constraintStart_toEndOf="@+id/txtUsuarioPerfil"
                app:layout_constraintTop_toTopOf="@+id/txtSemestre" />

            <TextView
                android:id="@+id/txtSemestre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-light"
                android:text=" - Semestre"
                android:textColor="@color/white"
                app:layout_constraintStart_toEndOf="@+id/txtCarrera"
                app:layout_constraintTop_toTopOf="@+id/txtUsuarioPerfil" />

            <TextView
                android:id="@+id/txtPublicaciones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="40dp"
                android:fontFamily="sans-serif-light"
                android:text="Publicaciones"
                android:textColor="@color/white"
                app:layout_constraintBottom_toTopOf="@+id/btnPublicacionesGuardadas"
                app:layout_constraintStart_toStartOf="parent" />

            <Button
                android:id="@+id/btnEditarPerfil"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginEnd="28dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/naranja_oscuro"
                android:text="Editar perfil"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <Button
                android:id="@+id/btnSeguir"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/naranja_oscuro"
                android:text="Dejar de seguir"
                android:visibility="gone"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <ImageView
                android:id="@+id/btnCerrarSesion"
                android:layout_width="40sp"
                android:layout_height="40sp"
                android:layout_gravity="top|right"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Cerrar sesión"
                android:focusable="true"
                android:src="@drawable/cerrar_sesion"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtBio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:fontFamily="sans-serif-light"
                android:text="Bio"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintBottom_toTopOf="@+id/contSeguidores"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txtCarrera" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/textView10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Publicaciones"
        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardPerfil" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeUserRefresh"
        android:layout_width="match_parent"
        android:layout_height="497dp"
        app:layout_constraintBottom_toTopOf="@+id/toolbarPerfil"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView10">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvUserPosts"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>