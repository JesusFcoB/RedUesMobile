<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="16dp"
    android:paddingHorizontal="4dp"
    android:paddingBottom="16dp"
    android:background="#F2F2F2"> <!-- Fondo gris para resaltar los items blancos -->

    <TextView
        android:id="@+id/tvComentariosTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Comentarios"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#5f0716"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvComentarios"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvComentariosTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_comentario" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/containerInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/rvComentarios">

        <EditText
            android:id="@+id/etNuevoComentario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Escribe un comentario..."
            android:textColorHint="#757575"
            android:textColor="#212121"
            android:padding="12dp"
            android:background="@drawable/edit_text_background"
            android:maxLines="3"
            android:inputType="textCapSentences|textMultiLine"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnEnviarComentario" />

        <ImageButton
            android:id="@+id/btnEnviarComentario"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Enviar comentario"
            app:layout_constraintBottom_toBottomOf="@id/etNuevoComentario"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/etNuevoComentario"
            app:tint="#5f0716" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>